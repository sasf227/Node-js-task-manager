<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<title>Create Task</title>

<link rel="stylesheet" href="/css/reset.css">
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/forms.css">

</head>
<body>

<div class="form-container">

<div class="form-card">

<h2>Create New Task</h2>

<form>



<!-- Title -->
<label>Task Title</label>
<input type="text" id="title" name="title" placeholder="Enter task title" required>

<!-- Description -->
<label>Description</label>
<textarea name="description" id="description" placeholder="Describe the task"></textarea>

<!-- Team Members -->
<label>Assign Users</label>
<input type="text" id="users" name="users" placeholder="Enter emails (comma separated)">

<!-- Milestones -->
<label>Milestones</label>
<textarea name="milestones" id="milestones" placeholder="Define milestones (e.g. Step 1, Step 2...)"></textarea>

<!-- Dates -->
<div class="date-group">

<div>
<label>Due To</label>
<input type="date" id="dueto" name="dueto">
</div>

</div>

<!-- Priority -->
<div class="priority-select">
    <label>Priority</label>

    <div class="priority-options">
        <input type="radio" id="low" name="priority" value="Low">
        <label for="low" class="priority low">Low</label>

        <input type="radio" id="medium" name="priority" value="Medium">
        <label for="medium" class="priority medium">Medium</label>

        <input type="radio" id="high" name="priority" value="High">
        <label for="high" class="priority high">High</label>
    </div>
</div>
</form>

<button class="btn primary full" onclick="createTask()">Create Task</button>
<p class="switch-text">
<a href="/home">Back to Dashboard</a>
</p>

</div>

</div>

<script>

    async function createTask () {
        event.preventDefault()
        const creator = `<%= user.username %>`;
        const users = [document.getElementById('users').value];
        const title = document.getElementById('title').value;
        const description = document.getElementById('description').value;
        const createdat = new Date();
        const dueto = document.getElementById('dueto').value;
        const milestones = [document.getElementById('milestones').value];
        const creatoremail = `<%= user.email %>`
        const priority = document.querySelector('input[name="priority"]:checked').value;
        const status = 'In Progress';

        const res = await fetch('/create/newTask', {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
            },
            body: JSON.stringify({
                creator,
                users,
                title,
                description,
                createdat,
                dueto,
                milestones,
                creatoremail,
                priority,
                status
            })
        });
        const data = await res.json();
        if (data.redirect) {
            window.location.href = data.redirect;
        } else if(data.error) {
            error_handler.innerHTML=`${data.error}`;
        };
    }
</script>
</body>
</html>